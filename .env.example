# Dotty Environment Variables
# Copy this to .env and fill in all values before running locally or deploying.

# Application
NODE_ENV=development
PORT=3000

# Clerk Authentication
CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME
CLERK_SECRET_KEY=sk_test_REPLACE_ME
CLERK_WEBHOOK_SECRET=whsec_REPLACE_ME

# PostgreSQL (Neon)
DATABASE_URL=postgresql://user:password@host.neon.tech/dotty?sslmode=require

# Redis (Upstash)
REDIS_URL=rediss://user:password@host.upstash.io

# Composio
COMPOSIO_API_KEY=cmp_REPLACE_ME
COMPOSIO_WEBHOOK_SECRET=whsec_REPLACE_ME

# LLM Provider (OpenAI-compatible)
OPENAI_API_KEY=sk-REPLACE_ME

# Cloudflare R2 (Object Storage)
R2_ACCOUNT_ID=REPLACE_ME
R2_ACCESS_KEY_ID=REPLACE_ME
R2_SECRET_ACCESS_KEY=REPLACE_ME
R2_BUCKET=dotty-attachments

# Mem0
MEM0_API_KEY=mem0_REPLACE_ME

# Observability
LOG_LEVEL=info